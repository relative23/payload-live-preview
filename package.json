{
  "name": "payload-live-preview",
  "version": "1.0.3",
  "description": "Live preview for Payload CMS in Astro and any SSR/static frontend (SvelteKit, Nuxt, Next.js, plain HTML). Patches the DOM live, no rebuild.",
  "author": "relative23",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./core": {
      "import": {
        "types": "./dist/core.d.ts",
        "default": "./dist/core.js"
      },
      "require": {
        "types": "./dist/core.d.cts",
        "default": "./dist/core.cjs"
      }
    },
    "./astro": {
      "import": {
        "types": "./dist/adapters/astro/index.d.ts",
        "default": "./dist/adapters/astro/index.js"
      }
    },
    "./nextjs": {
      "import": {
        "types": "./dist/adapters/nextjs/index.d.ts",
        "default": "./dist/adapters/nextjs/index.js"
      }
    },
    "./sveltekit": {
      "import": {
        "types": "./dist/adapters/sveltekit/index.d.ts",
        "default": "./dist/adapters/sveltekit/index.js"
      }
    },
    "./nuxt": {
      "import": {
        "types": "./dist/adapters/nuxt/index.d.ts",
        "default": "./dist/adapters/nuxt/index.js"
      }
    },
    "./codegen": {
      "import": {
        "types": "./dist/codegen.d.ts",
        "default": "./dist/codegen.js"
      },
      "require": {
        "types": "./dist/codegen.d.cts",
        "default": "./dist/codegen.cjs"
      }
    },
    "./codegen/astro": {
      "import": {
        "types": "./dist/codegen-astro.d.ts",
        "default": "./dist/codegen-astro.js"
      }
    },
    "./payload": {
      "import": {
        "types": "./dist/payload.d.ts",
        "default": "./dist/payload.js"
      },
      "require": {
        "types": "./dist/payload.d.cts",
        "default": "./dist/payload.cjs"
      }
    },
    "./astro/RichText.astro": "./dist/adapters/astro/RichText.astro",
    "./astro/middleware-entry": {
      "import": {
        "types": "./dist/adapters/astro/middleware-entry.d.ts",
        "default": "./dist/adapters/astro/middleware-entry.js"
      }
    }
  },
  "bin": {
    "pll-codegen": "./dist/codegen-cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "prepare": "npm run build:runtime",
    "build:runtime": "tsx scripts/build-runtime.ts",
    "build": "npm run build:runtime && tsup && npm run build:assets",
    "build:assets": "node -e \"require('node:fs').copyFileSync('src/adapters/astro/RichText.astro','dist/adapters/astro/RichText.astro')\"",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "test:bench": "vitest bench tests/benchmarks",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "check": "npm run typecheck && npm run lint && npm run test",
    "prepublishOnly": "npm run check && npm run build",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "npm run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.20.1",
    "@vitest/coverage-v8": "^4.1.10",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "ts-morph": "^28.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  },
  "keywords": [
    "astro",
    "astro-payload",
    "astro-cms",
    "astro-integration",
    "astro-live-preview",
    "payload",
    "payload-cms",
    "payload-live-preview",
    "payload-plugin",
    "live-preview",
    "preview",
    "cms",
    "headless",
    "headless-cms",
    "lexical",
    "sveltekit",
    "nuxt",
    "nextjs",
    "ssr",
    "framework-agnostic"
  ],
  "peerDependencies": {
    "astro": ">=4.0.0 <8.0.0",
    "ts-morph": "^28.0.0"
  },
  "peerDependenciesMeta": {
    "astro": {
      "optional": true
    },
    "ts-morph": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/relative23/payload-live-preview.git"
  },
  "bugs": {
    "url": "https://github.com/relative23/payload-live-preview/issues"
  },
  "homepage": "https://github.com/relative23/payload-live-preview#readme"
}
