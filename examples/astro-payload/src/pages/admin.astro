---
/**
 * Mock Payload admin — emulates the postMessage protocol so the demo
 * works without a real Payload backend.
 *
 * Visit this page in dev mode and type into the inputs to see updates
 * flow into the iframe in real time. The exact same flow drives the
 * Playwright integration tests.
 */
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Mock Payload Admin</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <style>
      :root {
        color-scheme: light dark;
        font-family:
          system-ui,
          -apple-system,
          'Segoe UI',
          sans-serif;
      }
      body {
        margin: 0;
        padding: 1rem;
        display: grid;
        grid-template-columns: 320px 1fr;
        gap: 1rem;
        min-height: 100vh;
        box-sizing: border-box;
      }
      form {
        display: grid;
        gap: 0.75rem;
        align-content: start;
      }
      label {
        display: grid;
        gap: 0.25rem;
        font-size: 0.85rem;
      }
      input,
      textarea {
        font: inherit;
        padding: 0.4rem 0.6rem;
        border-radius: 6px;
        border: 1px solid rgba(0, 0, 0, 0.2);
      }
      iframe {
        width: 100%;
        height: 100%;
        min-height: 90vh;
        border: 1px solid rgba(0, 0, 0, 0.15);
        border-radius: 8px;
      }
      h1 {
        margin: 0 0 1rem;
        font-size: 1rem;
      }
    </style>
  </head>
  <body>
    <form id="admin-form" data-testid="admin-form">
      <h1>Mock Admin</h1>
      <label>
        Title
        <input name="title" value="Hello from the demo" data-testid="title-input" />
      </label>
      <label>
        Subtitle
        <input
          name="subtitle"
          value="Type in the admin panel to see live updates."
          data-testid="subtitle-input"
        />
      </label>
      <label>
        Hero image URL
        <input
          name="heroUrl"
          value="https://images.unsplash.com/photo-1469474968028-56623f02e42e?w=1200"
          data-testid="hero-url-input"
        />
      </label>
      <label>
        Count
        <input name="count" type="number" value="12" data-testid="count-input" />
      </label>
      <label>
        CTA label
        <input name="ctaLabel" value="Visit Payload" data-testid="cta-label-input" />
      </label>
      <label>
        CTA URL
        <input name="ctaUrl" value="https://payloadcms.com" data-testid="cta-url-input" />
      </label>
      <label>
        Tags (comma separated)
        <input name="tags" value="astro, payload, live-preview" data-testid="tags-input" />
      </label>
    </form>

    <iframe id="preview" src="/" data-testid="preview-frame" title="Live preview"></iframe>

    <script is:inline>
      const form = document.getElementById('admin-form');
      const iframe = document.getElementById('preview');

      function buildData() {
        const fd = new FormData(form);
        return {
          title: String(fd.get('title') ?? ''),
          subtitle: String(fd.get('subtitle') ?? ''),
          hero: { url: String(fd.get('heroUrl') ?? ''), alt: 'Hero image' },
          count: Number(fd.get('count') ?? 0),
          publishedAt: new Date().toISOString(),
          tags: String(fd.get('tags') ?? '')
            .split(',')
            .map((t) => t.trim())
            .filter((t) => t.length > 0),
          ctaLabel: String(fd.get('ctaLabel') ?? ''),
          ctaUrl: String(fd.get('ctaUrl') ?? ''),
          body: {
            root: {
              children: [
                {
                  type: 'heading',
                  tag: 'h2',
                  children: [{ type: 'text', text: 'Rich text from Lexical' }],
                },
                {
                  type: 'paragraph',
                  children: [
                    { type: 'text', text: 'Live preview rendered at ' },
                    { type: 'text', text: new Date().toLocaleTimeString(), format: 1 },
                  ],
                },
              ],
            },
          },
        };
      }

      function sendUpdate() {
        const message = {
          type: 'payload-live-preview',
          data: buildData(),
          collectionSlug: 'pages',
          locale: 'en',
        };
        if (iframe.contentWindow) {
          iframe.contentWindow.postMessage(message, window.location.origin);
        }
      }

      let pending = null;
      form.addEventListener('input', () => {
        if (pending) clearTimeout(pending);
        pending = setTimeout(sendUpdate, 16);
      });

      // When the preview signals ready, push the initial state so the
      // user sees their typing instantly mirrored after a refresh.
      window.addEventListener('message', (event) => {
        if (event.origin !== window.location.origin) return;
        const data = event.data;
        if (data && data.type === 'payload-live-preview' && data.ready === true) {
          sendUpdate();
        }
      });
    </script>
  </body>
</html>
